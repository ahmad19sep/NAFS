# Supabase — get from supabase.com > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Gemini — get from aistudio.google.com > Get API Key
GEMINI_API_KEY=your-gemini-api-key

# Web Push — generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:ahmadsiddique665@gmail.com

# App URL — used for web push and cron callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron secret — any long random string, used to authenticate Vercel Cron calls
CRON_SECRET=

# Resend (email reports) — get free key at resend.com (3,000/mo free)
RESEND_API_KEY=
# Optional: override sender. Defaults to onboarding@resend.dev (works without domain verification for testing)
NAFS_EMAIL_FROM=NAFS <noreply@yourdomain.com>
# Dev only: redirect ?test=1 emails to this address (Resend free tier without
# domain verification only allows sending to your own Resend account email).
RESEND_DEV_RECIPIENT=

# Groq Cloud (chat fallback) — get free key at console.groq.com
GROQ_API_KEY=
